#!/usr/bin/env bash
set -euo pipefail

echo "SwarmFish — Dependency Setup"
echo "============================"
echo ""

INSTALL_BREW_PKGS=false
INSTALL_PIP_PKGS=false
INSTALL_NPM_PKGS=false

BREW_PKGS=()
PIP_PKGS=()
NPM_PKGS=()

# --- Check brew-installable tools ---

if ! command -v jq &>/dev/null; then
  echo "[!] jq not found (required for /swarmfish:swarm query)"
  BREW_PKGS+=("jq")
  INSTALL_BREW_PKGS=true
else
  echo "[✓] jq $(jq --version 2>&1)"
fi

if ! command -v neato &>/dev/null; then
  echo "[!] graphviz not found (enables force-directed SVG graph layouts)"
  BREW_PKGS+=("graphviz")
  INSTALL_BREW_PKGS=true
else
  echo "[✓] graphviz $(neato -V 2>&1 | head -1)"
fi

# --- Check pip-installable tools ---

if ! python3 -c "import networkx" 2>/dev/null; then
  echo "[!] networkx not found (enables PageRank, centrality, community detection)"
  PIP_PKGS+=("networkx" "numpy")
  INSTALL_PIP_PKGS=true
else
  echo "[✓] networkx $(python3 -c 'import networkx; print(networkx.__version__)')"
fi

if ! python3 -c "import rich" 2>/dev/null; then
  echo "[!] rich not found (pretty terminal output)"
  PIP_PKGS+=("rich")
  INSTALL_PIP_PKGS=true
else
  echo "[✓] rich (installed)"
fi

if ! python3 -c "import weasyprint" 2>/dev/null; then
  echo "[!] weasyprint not found (HTML-to-PDF rendering)"
  PIP_PKGS+=("weasyprint")
  INSTALL_PIP_PKGS=true
else
  echo "[✓] weasyprint $(python3 -c 'import weasyprint; print(weasyprint.__version__)')"
fi

# --- Check npm-installable tools ---

if ! command -v md-to-pdf &>/dev/null; then
  echo "[!] md-to-pdf not found (PDF export from markdown)"
  NPM_PKGS+=("md-to-pdf")
  INSTALL_NPM_PKGS=true
else
  echo "[✓] md-to-pdf (installed)"
fi

if ! command -v mmdc &>/dev/null; then
  echo "[·] mermaid-cli not found (optional fallback graph renderer)"
  NPM_PKGS+=("@mermaid-js/mermaid-cli")
  INSTALL_NPM_PKGS=true
else
  echo "[✓] mermaid-cli (installed)"
fi

echo ""

# --- Install missing tools ---

if $INSTALL_BREW_PKGS || $INSTALL_PIP_PKGS || $INSTALL_NPM_PKGS; then
  echo "The following will be installed:"
  $INSTALL_BREW_PKGS && echo "  brew: ${BREW_PKGS[*]}"
  $INSTALL_PIP_PKGS && echo "  pip:  ${PIP_PKGS[*]}"
  $INSTALL_NPM_PKGS && echo "  npm:  ${NPM_PKGS[*]}"
  echo ""
  echo "Proceed? (y/n)"
  read -r REPLY
  if [[ "$REPLY" =~ ^[Yy]$ ]]; then

    # Brew packages
    if $INSTALL_BREW_PKGS; then
      if command -v brew &>/dev/null; then
        echo "Installing via brew: ${BREW_PKGS[*]}..."
        brew install "${BREW_PKGS[@]}"
      elif command -v apt-get &>/dev/null; then
        echo "Installing via apt: ${BREW_PKGS[*]}..."
        sudo apt-get install -y "${BREW_PKGS[@]}"
      elif command -v dnf &>/dev/null; then
        echo "Installing via dnf: ${BREW_PKGS[*]}..."
        sudo dnf install -y "${BREW_PKGS[@]}"
      else
        echo "Please install manually: ${BREW_PKGS[*]}"
      fi
    fi

    # Pip packages
    if $INSTALL_PIP_PKGS; then
      echo "Installing via pip: ${PIP_PKGS[*]}..."
      pip3 install "${PIP_PKGS[@]}" 2>/dev/null || \
      pip3 install --user "${PIP_PKGS[@]}" 2>/dev/null || \
      pip3 install --break-system-packages "${PIP_PKGS[@]}" 2>/dev/null || \
      echo "Please install manually: pip install ${PIP_PKGS[*]}"
    fi

    # npm packages
    if $INSTALL_NPM_PKGS; then
      echo "Installing via npm: ${NPM_PKGS[*]}..."
      npm install -g "${NPM_PKGS[@]}" 2>/dev/null || \
      echo "Please install manually: npm i -g ${NPM_PKGS[*]}"
    fi

    echo ""
    echo "Setup complete. Run /swarmfish:swarm check to verify."
  else
    echo "Skipped. You can install later with: /swarmfish:swarm setup"
  fi
else
  echo "All dependencies already installed!"
fi
